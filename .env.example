# Local development sample. Copy to .env and fill in.
# For Railway, set these in the project dashboard instead.

# Supabase PostgreSQL connection — uses BOTH a pooled (runtime) and direct (migrations) URL.
#
# DATABASE_URL: Transaction pooler (port 6543) — efficient for many short queries.
#   Get from: Supabase Dashboard → Settings → Database → Connection string → Transaction pooler
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-X-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20"
#
# DIRECT_URL: Session pooler (port 5432, same hostname). Used by `prisma migrate`.
#   IMPORTANT: Do NOT use `db.[ref].supabase.co:5432` here — that endpoint is IPv6-only
#   and Railway (plus many hosts) can't reach it. The session pooler at port 5432 works.
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-X-[region].pooler.supabase.com:5432/postgres"

# Long random string (32+ chars). Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string-min-32-chars-xxxxxxxxx"

# First-run admin credentials (only used on initial seed)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Public URL — used for sitemap.xml, canonical URLs, OG tags
SITE_URL="http://localhost:3000"

# Where uploaded files (product images, bank slips) live on disk.
# On Railway, set this to /app/data/uploads and mount a volume at /app/data.
# Leave unset locally — defaults to public/uploads.
# UPLOAD_DIR=/app/data/uploads

# Optional 3rd-party keys — can also be edited later via Admin → Settings.
KOOMBIYO_API_KEY=""
DEEPSEEK_API_KEY=""
OPENAI_API_KEY="sk-..."

# SMS gateway — Notify.lk (Sri Lankan provider)
# Sign up at https://app.notify.lk → API Settings → copy the values below.
# Leave all three EMPTY for development (OTP codes will just be logged to console).
NOTIFY_LK_USER_ID=""
NOTIFY_LK_API_KEY=""
NOTIFY_LK_SENDER_ID=""    # e.g. "NotifyDEMO" until your business sender id is approved
