generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model User {
  id            Int      @id @default(autoincrement())
  phone         String   @unique
  fullName      String
  passwordHash  String
  discountRate  Float    @default(0)
  // Saved delivery details — auto-filled into checkout for repeat orders
  email         String?
  addressLine1  String?
  addressLine2  String?
  districtName  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  orders        Order[]
  reviews       Review[]
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)  // failed verify attempts — locks after a threshold
  createdAt DateTime @default(now())

  @@index([phone])
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  nameSi    String?
  nameTa    String?
  slug      String    @unique
  imageUrl  String?
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  price       Float
  salePrice   Float?
  sku         String?   @unique
  stock       Int       @default(0)
  // Single source of truth for availability — when true, blocks checkout and
  // shows an "Out of stock" badge. The legacy `stock` column is kept for now
  // but is no longer used for availability checks.
  outOfStock  Boolean   @default(false)
  unitQty     Int?      // e.g. 100 (for "100 pieces") or 10 (for "10 yards")
  unitType    String?   // "pieces" | "yards" | "meters" | "feet" | "cm"
  imageUrl    String?
  images      String?   // JSON array
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  onOffer     Boolean   @default(false)
  featured    Boolean   @default(false)
  active      Boolean   @default(true)
  metaTitle   String?
  metaDesc    String?
  // pgvector embedding for semantic search (managed via raw SQL — Prisma treats this
  // type as opaque so it can't be SELECTed directly by the client, only via $queryRaw)
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orderItems  OrderItem[]
  reviews     Review[]
  variants    ProductVariant[]
  chatSuggestions ChatSuggestion[]

  @@index([categoryId])
  @@index([onOffer])
  @@index([featured])
}

model District {
  id           Int    @id @default(autoincrement())
  name         String @unique
  deliveryFee  Float  @default(450)
  cities       City[]
}

model City {
  id          Int      @id @default(autoincrement())
  name        String
  districtId  Int
  district    District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  deliveryFee Float?

  @@unique([name, districtId])
  @@index([districtId])
}

model Customer {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String?
  phone     String
  createdAt DateTime @default(now())
  orders    Order[]

  @@index([phone])
  @@index([email])
}

model Order {
  id              Int      @id @default(autoincrement())
  orderNumber     String   @unique
  customerId      Int?
  customer        Customer? @relation(fields: [customerId], references: [id])
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id])
  fullName        String
  phone           String
  email           String?
  addressLine1    String
  addressLine2    String?
  districtName    String
  cityName        String
  notes           String?
  subtotal        Float
  accountDiscount       Float    @default(0)
  tierDiscount          Float    @default(0)
  couponCode            String?
  couponDiscount        Float    @default(0)
  deliveryFee     Float
  total           Float
  paymentMethod   String   // "cod" | "bank"
  bankSlipUrl     String?
  status          String   @default("pending")
  source          String?
  sessionId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  items           OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Float
  quantity  Int

  @@index([orderId])
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String  // "color" | "size" | "length"
  name      String
  nameSi    String? // Sinhala translation (auto-generated)
  nameTa    String? // Tamil translation (auto-generated)
  imageUrl  String?
  price     Float?
  salePrice Float?
  sortOrder Int     @default(0)
  // Per-variant availability — if true, customer can't pick this variant
  outOfStock Boolean @default(false)

  @@index([productId])
}

model Coupon {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  type         String   // "percent" | "fixed"
  value        Float    // % for percent, LKR for fixed
  minSubtotal  Float    @default(0)
  maxDiscount  Float?   // cap for percent coupons
  usageLimit   Int?     // total uses across all customers
  usedCount    Int      @default(0)
  perUserLimit Int?     // max uses per user
  expiresAt    DateTime?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([active])
}

model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  name      String   // display name (snapshot)
  rating    Int      // 1..5
  title     String?
  body      String
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([approved])
}

model Setting {
  key   String @id
  value String
}

model Banner {
  id         Int      @id @default(autoincrement())
  imageUrl   String
  headline   String?
  subtitle   String?
  buttonText String?
  buttonHref String?
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([active])
}

model AnalyticsSession {
  id          String   @id
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())
  source      String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  userAgent   String?
  pageViews   Int      @default(0)
  totalMs     Int      @default(0)
  // Owned-analytics phone linking — SHA-256 hash for matching + last 4 digits for
  // eyeball recognition in the dashboard. Full number is NEVER stored here (it
  // lives in Order/OMS). Attached at checkout / for logged-in users.
  phoneHash   String?
  phoneLast4  String?
  events      AnalyticsEvent[]

  @@index([phoneHash])
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  sessionId String
  session   AnalyticsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String
  path      String?
  productId Int?
  quantity  Int?
  value     Float?
  meta      String?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
}

model Cart {
  id        String   @id
  itemsJson String
  total     Float    @default(0)
  abandoned Boolean  @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ===== Machines (industrial sewing machines — brand Prime) =====
// A separate model from Product: no cart/checkout/variants. Ordering is
// Call + WhatsApp only. Admin-managed via /admin/machines.
model Machine {
  id           Int      @id @default(autoincrement())
  modelNumber  String                    // SEO anchor, e.g. "JK-8720"
  brand        String   @default("Prime")
  name         String
  slug         String   @unique          // e.g. "prime-jk-8720"
  category     String?                   // e.g. "Single Needle Lockstitch"
  price        Float?                    // nullable -> "Enquire for price"
  imageUrl     String?                   // primary image
  images       String?                   // JSON array of gallery image URLs
  description  String?
  specs        String?                   // JSON array of { key, value } spec rows
  warrantyInfo String?                   // trust / warranty text
  // SEO: cross-brand equivalence. Same physical machine sold under other brands
  // with different model numbers — captures competitor-brand searches.
  equivalents  String?                   // JSON array of { brand, model, note? }
  faq          String?                   // JSON array of { q, a } -> FAQPage schema
  seoIntro     String?                   // optional keyword-rich intro paragraph
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
}

/// A machine type ("Embroidery Machines") — the SEO hub layer. Machines link
/// via Machine.category === MachineType.name (string join keeps bulk upload
/// simple; the type PATCH API cascades renames). Each type gets a hub page at
/// /machines/{slug} targeting head terms like "embroidery machine price sri
/// lanka" — the real search volume, unlike house-brand model numbers.
model MachineType {
  id        Int      @id @default(autoincrement())
  name      String   @unique   // join key to Machine.category
  slug      String   @unique   // "embroidery-machines"
  blurb     String?            // one-liner for the browse card
  seoIntro  String?            // keyword-rich hub intro (competitor brands at class level)
  faq       String?            // JSON [{q,a}] -> FAQPage schema
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A "leave your number, we'll call you back" enquiry from a machine page.
/// Unlike AnalyticsSession (hash + last-4 only), this DELIBERATELY stores the
/// full name + phone: the whole point is that the shop calls the customer back.
model MachineLead {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String
  message     String?
  machineId   Int?                       // machine enquired about (if known)
  modelNumber String?                    // denormalised for quick eyeballing
  handled     Boolean  @default(false)   // owner ticks off once called
  createdAt   DateTime @default(now())

  @@index([handled])
  @@index([createdAt])
}

// ===== Customer profiling =====
// One row per (browserId, optional userId). Built by the profile-builder job
// every 15 min from existing AnalyticsEvent / Order / Cart / ChatSession data.
// Powers personalized recommendations + situational pricing later on.

model CustomerProfile {
  id                     Int      @id @default(autoincrement())
  browserId              String   @unique  // cookie-based anonymous id
  userId                 Int?     @unique  // populated when the visitor signs up

  // Classifier output (one of:
  //   professional_tailor | boutique_owner | hobbyist | bulk_event_buyer |
  //   gifter | student | casual_browser | unknown)
  customerType           String   @default("unknown")
  typeConfidence         Float    @default(0)   // 0..1

  // Behavioral scores (all 0..1 unless noted)
  engagementScore        Float    @default(0)   // 0..100
  ltv                    Float    @default(0)   // total LKR ordered
  aov                    Float    @default(0)   // avg order value
  orderCount             Int      @default(0)
  cartAbandonmentRate    Float    @default(0)
  discountResponsiveness Float    @default(0)

  // Recency
  firstSeenAt            DateTime @default(now())
  lastSeenAt             DateTime @default(now())
  lastOrderAt            DateTime?

  // Preferences
  topCategories          String?  // JSON array of category slugs
  topPriceRange          Float?   // median price of products they engage with
  preferredLanguage      String?
  deviceClass            String?

  // Interest vector — averaged embedding of products they've viewed/added/ordered
  interestVector         Unsupported("vector(1536)")?

  updatedAt              DateTime @updatedAt

  @@index([customerType])
  @@index([lastSeenAt])
  @@index([userId])
}

// ===== AI Helper feedback loop =====
// Records each AI Helper conversation + every suggestion shown, plus implicit
// (add-to-cart, ordered) and explicit (thumbs, star rating) signals. Used to
// build the AI Insights admin page and (later) feed the model with what works.

model ChatSession {
  id                String   @id @default(cuid())
  // Anonymous browser fingerprint OR authenticated user id (or both)
  browserId         String
  userId            Int?
  // First user message — useful for grouping similar queries
  queryText         String
  language          String?  // detected language code
  // Implicit outcome signals
  totalSuggestions  Int      @default(0)
  addedCount        Int      @default(0)
  orderId           Int?     // attributed order, if any
  attributedAt      DateTime?
  // Explicit feedback
  ratingScore       Int?     // 1..5
  ratingComment     String?
  ratedAt           DateTime?
  // Conversation transcript (JSON array of {role, content})
  transcript        String   // JSON string
  startedAt         DateTime @default(now())
  lastMessageAt     DateTime @default(now()) @updatedAt
  suggestions       ChatSuggestion[]

  @@index([browserId])
  @@index([userId])
  @@index([startedAt])
  @@index([orderId])
  @@index([ratingScore])
}

model ChatSuggestion {
  id              Int      @id @default(autoincrement())
  sessionId       String
  session         ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product  @relation(fields: [productId], references: [id])
  reason          String   // AI's stated reason at time of suggestion
  quantity        Int      @default(1)
  similarityScore Float?   // pgvector match score at suggestion time
  // Explicit
  thumbsUp        Boolean? // null = unrated
  thumbsAt        DateTime?
  // Implicit
  addedToCart     Boolean  @default(false)
  addedToCartAt   DateTime?
  inOrderId       Int?     // order this product appeared in (within attribution window)
  createdAt       DateTime @default(now())

  @@index([sessionId])
  @@index([productId])
  @@index([createdAt])
}
