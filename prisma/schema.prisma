generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model User {
  id            Int      @id @default(autoincrement())
  phone         String   @unique
  fullName      String
  passwordHash  String
  discountRate  Float    @default(0)
  // Saved delivery details — auto-filled into checkout for repeat orders
  email         String?
  addressLine1  String?
  addressLine2  String?
  districtName  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  orders        Order[]
  reviews       Review[]
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  nameSi    String?
  nameTa    String?
  slug      String    @unique
  imageUrl  String?
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  price       Float
  salePrice   Float?
  sku         String?   @unique
  stock       Int       @default(0)
  // Single source of truth for availability — when true, blocks checkout and
  // shows an "Out of stock" badge. The legacy `stock` column is kept for now
  // but is no longer used for availability checks.
  outOfStock  Boolean   @default(false)
  unitQty     Int?      // e.g. 100 (for "100 pieces") or 10 (for "10 yards")
  unitType    String?   // "pieces" | "yards" | "meters" | "feet" | "cm"
  imageUrl    String?
  images      String?   // JSON array
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  onOffer     Boolean   @default(false)
  featured    Boolean   @default(false)
  active      Boolean   @default(true)
  metaTitle   String?
  metaDesc    String?
  // pgvector embedding for semantic search (managed via raw SQL — Prisma treats this
  // type as opaque so it can't be SELECTed directly by the client, only via $queryRaw)
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orderItems  OrderItem[]
  reviews     Review[]
  variants    ProductVariant[]
  chatSuggestions ChatSuggestion[]

  @@index([categoryId])
  @@index([onOffer])
  @@index([featured])
}

model District {
  id           Int    @id @default(autoincrement())
  name         String @unique
  deliveryFee  Float  @default(450)
  cities       City[]
}

model City {
  id          Int      @id @default(autoincrement())
  name        String
  districtId  Int
  district    District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  deliveryFee Float?

  @@unique([name, districtId])
  @@index([districtId])
}

model Customer {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String?
  phone     String
  createdAt DateTime @default(now())
  orders    Order[]

  @@index([phone])
  @@index([email])
}

model Order {
  id              Int      @id @default(autoincrement())
  orderNumber     String   @unique
  customerId      Int?
  customer        Customer? @relation(fields: [customerId], references: [id])
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id])
  fullName        String
  phone           String
  email           String?
  addressLine1    String
  addressLine2    String?
  districtName    String
  cityName        String
  notes           String?
  subtotal        Float
  accountDiscount       Float    @default(0)
  tierDiscount          Float    @default(0)
  couponCode            String?
  couponDiscount        Float    @default(0)
  deliveryFee     Float
  total           Float
  paymentMethod   String   // "cod" | "bank"
  bankSlipUrl     String?
  status          String   @default("pending")
  source          String?
  sessionId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  items           OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Float
  quantity  Int

  @@index([orderId])
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String  // "color" | "size" | "length"
  name      String
  nameSi    String? // Sinhala translation (auto-generated)
  nameTa    String? // Tamil translation (auto-generated)
  imageUrl  String?
  price     Float?
  salePrice Float?
  sortOrder Int     @default(0)
  // Per-variant availability — if true, customer can't pick this variant
  outOfStock Boolean @default(false)

  @@index([productId])
}

model Coupon {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  type         String   // "percent" | "fixed"
  value        Float    // % for percent, LKR for fixed
  minSubtotal  Float    @default(0)
  maxDiscount  Float?   // cap for percent coupons
  usageLimit   Int?     // total uses across all customers
  usedCount    Int      @default(0)
  perUserLimit Int?     // max uses per user
  expiresAt    DateTime?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([active])
}

model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  name      String   // display name (snapshot)
  rating    Int      // 1..5
  title     String?
  body      String
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([approved])
}

model Setting {
  key   String @id
  value String
}

model Banner {
  id         Int      @id @default(autoincrement())
  imageUrl   String
  headline   String?
  subtitle   String?
  buttonText String?
  buttonHref String?
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([active])
}

model AnalyticsSession {
  id          String   @id
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())
  source      String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  userAgent   String?
  pageViews   Int      @default(0)
  totalMs     Int      @default(0)
  events      AnalyticsEvent[]
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  sessionId String
  session   AnalyticsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String
  path      String?
  productId Int?
  quantity  Int?
  value     Float?
  meta      String?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
}

model Cart {
  id        String   @id
  itemsJson String
  total     Float    @default(0)
  abandoned Boolean  @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ===== Customer profiling =====
// One row per (browserId, optional userId). Built by the profile-builder job
// every 15 min from existing AnalyticsEvent / Order / Cart / ChatSession data.
// Powers personalized recommendations + situational pricing later on.

model CustomerProfile {
  id                     Int      @id @default(autoincrement())
  browserId              String   @unique  // cookie-based anonymous id
  userId                 Int?     @unique  // populated when the visitor signs up

  // Classifier output (one of:
  //   professional_tailor | boutique_owner | hobbyist | bulk_event_buyer |
  //   gifter | student | casual_browser | unknown)
  customerType           String   @default("unknown")
  typeConfidence         Float    @default(0)   // 0..1

  // Behavioral scores (all 0..1 unless noted)
  engagementScore        Float    @default(0)   // 0..100
  ltv                    Float    @default(0)   // total LKR ordered
  aov                    Float    @default(0)   // avg order value
  orderCount             Int      @default(0)
  cartAbandonmentRate    Float    @default(0)
  discountResponsiveness Float    @default(0)

  // Recency
  firstSeenAt            DateTime @default(now())
  lastSeenAt             DateTime @default(now())
  lastOrderAt            DateTime?

  // Preferences
  topCategories          String?  // JSON array of category slugs
  topPriceRange          Float?   // median price of products they engage with
  preferredLanguage      String?
  deviceClass            String?

  // Interest vector — averaged embedding of products they've viewed/added/ordered
  interestVector         Unsupported("vector(1536)")?

  updatedAt              DateTime @updatedAt

  @@index([customerType])
  @@index([lastSeenAt])
  @@index([userId])
}

// ===== AI Helper feedback loop =====
// Records each AI Helper conversation + every suggestion shown, plus implicit
// (add-to-cart, ordered) and explicit (thumbs, star rating) signals. Used to
// build the AI Insights admin page and (later) feed the model with what works.

model ChatSession {
  id                String   @id @default(cuid())
  // Anonymous browser fingerprint OR authenticated user id (or both)
  browserId         String
  userId            Int?
  // First user message — useful for grouping similar queries
  queryText         String
  language          String?  // detected language code
  // Implicit outcome signals
  totalSuggestions  Int      @default(0)
  addedCount        Int      @default(0)
  orderId           Int?     // attributed order, if any
  attributedAt      DateTime?
  // Explicit feedback
  ratingScore       Int?     // 1..5
  ratingComment     String?
  ratedAt           DateTime?
  // Conversation transcript (JSON array of {role, content})
  transcript        String   // JSON string
  startedAt         DateTime @default(now())
  lastMessageAt     DateTime @default(now()) @updatedAt
  suggestions       ChatSuggestion[]

  @@index([browserId])
  @@index([userId])
  @@index([startedAt])
  @@index([orderId])
  @@index([ratingScore])
}

model ChatSuggestion {
  id              Int      @id @default(autoincrement())
  sessionId       String
  session         ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product  @relation(fields: [productId], references: [id])
  reason          String   // AI's stated reason at time of suggestion
  quantity        Int      @default(1)
  similarityScore Float?   // pgvector match score at suggestion time
  // Explicit
  thumbsUp        Boolean? // null = unrated
  thumbsAt        DateTime?
  // Implicit
  addedToCart     Boolean  @default(false)
  addedToCartAt   DateTime?
  inOrderId       Int?     // order this product appeared in (within attribution window)
  createdAt       DateTime @default(now())

  @@index([sessionId])
  @@index([productId])
  @@index([createdAt])
}
